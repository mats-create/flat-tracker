rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow read, write: if request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
    }

    match /households/{householdId}/profiles/{profileId} {
      allow read, write: if request.auth.uid in
        get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    match /listings/{listingId} {
      // Inloggade användare kan läsa
      allow read: if request.auth != null;
      // Skrivning endast via Admin SDK (Cloud Functions) — blockerad för klienter
      allow write: if false;
    }

    match /areas/{areaId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
